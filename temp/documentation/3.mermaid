flowchart LR
    subgraph Legend [Сценарий 3: Проверка свежести]
    end

    Ext[Внешний класс] -->|"запрос проверки свежести"| DH[DataHandler]

    DH -->|"запрос данных для проверки"| LD[Loader]
    LD -->|"чтение"| JS[(jsonstore)]
    JS -->|"данные"| LD
    LD -->|"данные"| DH

    DH -->|"передача данных"| UD[UpdateDecider]
    UD -->|"решение (обновлять/нет)"| DH

    %% Разделение потоков с явным размещением
    DH -->|"если не обновлять"| Ext

    DH -->|"если обновлять"| DG[DataGetter]
    DG -->|"сырые данные"| DH
    DH -->|"сырые данные"| DP[DataParser]
    DP -->|"обработанные данные"| DH
    DH -->|"обработанные данные"| SV[Saver]
    SV -->|"сохранение"| JS
    SV -->|"execution code"| DH
    DH -->|"execution code (обновление выполнено)"| Ext