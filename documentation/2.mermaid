    subgraph Legend [Сценарий 2: Запрос данных]
    end

    Ext[Внешний класс] -->|"запрос данных (тег клана)"| DH[DataHandler]

    DH -->|"запрос данных по тегу"| LD[Loader]
    LD -->|"чтение"| JS[(jsonstore)]
    JS -->|"данные"| LD
    LD -->|"данные + Loader execution code"| DH

    DH -->|"данные + DataHandler execution code"| Ext